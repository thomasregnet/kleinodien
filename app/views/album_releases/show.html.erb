<h1><%= @album_release.title %></h1>
<p>by <b><%= @album_release.head.artist_credit.name %></b></p>
<p>
  <ul>
    <%= render 'labels', labels: @album_release.labels %>
  </ul>

  <h3>formats</h3>
  <ul>
    <%= render "formats", formats: @album_release.formats %>
  </ul>
</p>

<h2>tracks</h2>
<ul>
  <%= render "tracks", tracks: @album_release.tracks %>
</ul>

<h2>identifiers</h2>
<ul>
  <%= render "identifiers", identifiers: @album_release.identifiers %>
</ul>

<h2>credits</h2>
<ul>
  <%= render "credits", credits: @album_release.credits %>
</ul>
<h2>reference</h2>
  <%= @album_release.reference.supplier.name %>: <%= @album_release.reference.identifier %>
