<h1><%= @album_release.title %></h1>

<p>
  <ul>
    <%= render partial: "labels",
               locals:  { labels: @album_release.labels } %>

  </ul>
  <h3>formats</h3>
  <ul>
    <% @album_release.formats.each do |f| %>
      <li>
	<%= format_quantity_multiplied_name_for(f) %>
        <%= format_details_for(f) %>
        <%= f.note if f.note %>
      </li>
    <% end %>
  </ul>
</p>
<h2>tracks</h2>
<ul>
  <% @album_release.tracks.each do |t| %>
    <li><%= t.release.title %></li>
  <% end %>
</ul>

<h2>identifiers</h2>
<ul>
  <% @album_release.identifiers.each do |i| %>
    <li><%= identifier_disambiguation_for(i) %></li>
  <% end %>
</ul>
