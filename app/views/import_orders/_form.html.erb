<%= form_with(model: import_order, local: true) do |form| %>
  <% if import_order.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(import_order.errors.count, "error") %> prohibited this import_order from being saved:</h2>

      <ul>
        <% import_order.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :code %>
    <%= form.text_area :code %>
  </div>

  <div class="field">
    <%= form.label :state %>
    <%= form.text_area :state %>
  </div>

  <div class="field">
    <%= form.label :type %>
    <%= form.text_area :type %>
  </div>

  <div class="field">
    <%= form.label :uri %>
    <%= form.text_area :uri %>
  </div>

  <div class="field">
    <%= form.label :user_id %>
    <%= form.text_field :user_id %>
  </div>

  <div class="field">
    <%= form.label :requests_count %>
    <%= form.number_field :requests_count %>
  </div>

  <div class="field">
    <%= form.label :import_queue_id %>
    <%= form.text_field :import_queue_id %>
  </div>

  <div class="actions">
    <%= form.submit %>
  </div>
<% end %>
