<p id="notice"><%= notice %></p>

<section class="hero">
  <div class="container">
    <div class="hero-body">
      <h1 class="title">Artists</h1>
    </div>
  </div>
</section>

<section>
  <div class="content">
    <ul>
      <% @artists.each do |artist| %>
        <li>
          <%= link_to artist.name, artist %>
          <% if artist.disambiguation %>
            - <span has-text-grey><%= artist.disambiguation %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</section>

<p>
  <%= paginate @artists %>
</p>
<%= link_to 'New Artist', new_artist_path %>
